# ================================
# Comandas Admin - Entorno (Vite)
# ================================

# URL GraphQL HTTP (consulta/mutaciones)
# Opcional: por defecto usa http://localhost:4100/graphql
VITE_GRAPHQL_HTTP_URL=http://localhost:4100/graphql

# URL GraphQL WebSocket (suscripciones)
# Opcional: por defecto usa ws://localhost:4100/graphql
VITE_GRAPHQL_WS_URL=ws://localhost:4100/graphql

# Si no hay token guardado en localStorage, usa este token
# Opcional
VITE_GRAPHQL_TOKEN=

# Si es true, usa datos mock y no requiere auth real
# Opcional: por defecto false
VITE_USE_MOCK=false

# Credenciales para validar usuario contra backend
# Requeridas cuando VITE_USE_MOCK=false
VITE_V3_LOGIN=
VITE_V3_PSWD=

# Filtros iniciales para query de comandas
# Opcionales (si no vienen del token/authContext)
VITE_EMPRESA=
VITE_SUCURSAL=
